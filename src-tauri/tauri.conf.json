{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "иґґзєёз•ЄиЊ„й’џ",
  "version": "1.1.0",
  "identifier": "com.stickerpomodoro.timer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "иґґзєёз•ЄиЊ„й’џ",
        "width": 560,
        "height": 620,
        "minWidth": 460,
        "minHeight": 540,
        "center": true,
        "resizable": true,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": ["icons/icon.png", "icons/icon.ico"]
  }
}
